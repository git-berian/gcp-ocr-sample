{
  "name": "docai-expense-parser-docker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint --no-error-on-unmatched-pattern src/ tests/",
    "lint:fix": "eslint --no-error-on-unmatched-pattern src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google-cloud/documentai": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
