{
  "name": "@docai/functions",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint --no-error-on-unmatched-pattern src/",
    "lint:fix": "eslint --no-error-on-unmatched-pattern src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "start": "npx functions-framework --target=parseDocument --source=dist/"
  },
  "dependencies": {
    "@google-cloud/documentai": "^9.5.0",
    "@google-cloud/functions-framework": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
