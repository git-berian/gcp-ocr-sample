{
  "name": "docai-expense-parser",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@docai/cli",
    "lint": "npm run lint --workspace=@docai/cli",
    "lint:fix": "npm run lint:fix --workspace=@docai/cli",
    "format": "npm run format --workspace=@docai/cli",
    "format:check": "npm run format:check --workspace=@docai/cli",
    "test": "npm run test --workspace=@docai/cli",
    "test:unit": "npm run test:unit --workspace=@docai/cli",
    "test:integration": "npm run test:integration --workspace=@docai/cli",
    "test:coverage": "npm run test:coverage --workspace=@docai/cli",
    "test:watch": "npm run test:watch --workspace=@docai/cli",
    "prepare": "husky",
    "docker:setup": "docker-compose -f packages/cli/docker/docker-compose.yml run --rm ocr npm ci --ignore-scripts",
    "docker:build": "docker-compose -f packages/cli/docker/docker-compose.yml build",
    "docker:lint": "docker-compose -f packages/cli/docker/docker-compose.yml run --rm ocr npm run lint",
    "docker:format:check": "docker-compose -f packages/cli/docker/docker-compose.yml run --rm ocr npm run format:check",
    "docker:test": "docker-compose -f packages/cli/docker/docker-compose.yml run --rm ocr npm run test",
    "docker:test:coverage": "docker-compose -f packages/cli/docker/docker-compose.yml run --rm ocr npm run test:coverage",
    "docker:sh": "docker-compose -f packages/cli/docker/docker-compose.yml run --rm ocr bash"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3"
  },
  "lint-staged": {
    "packages/cli/src/**/*.ts": [
      "eslint --no-error-on-unmatched-pattern --fix",
      "prettier --write"
    ],
    "packages/cli/tests/**/*.ts": [
      "eslint --no-error-on-unmatched-pattern --fix",
      "prettier --write"
    ],
    "packages/functions/src/**/*.ts": [
      "eslint --no-error-on-unmatched-pattern --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "volta": {
    "node": "20.20.1"
  }
}
